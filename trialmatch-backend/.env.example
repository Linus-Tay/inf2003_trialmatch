# ============================================================
# TrialMatch backend environment
# Copy this file to trialmatch-backend/.env if running backend directly.
# The values should match the root .env used by Docker.
# ============================================================

APP_NAME=TrialMatch Backend
FRONTEND_ORIGIN=http://localhost:5173

MARIADB_HOST=127.0.0.1
MARIADB_PORT=3307
MARIADB_USER=trialmatch_user
MARIADB_PASSWORD=trialmatch_password
MARIADB_DB=trialmatch_db

MONGO_DB=trialmatch_nosql
MONGO_URI=mongodb://trialmatch_mongo_user:trialmatch_mongo_password@localhost:27017/trialmatch_nosql?authSource=trialmatch_nosql

JWT_SECRET_KEY=change-this-to-a-long-random-secret-before-final-demo
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
